rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─────────────────────────────────────────────────────────────────
    // Reglas simples: Si estás autenticado, puedes leer/escribir
    // La validación de roles se hace en la APP
    // ─────────────────────────────────────────────────────────────────

    // TODOS los documentos autenticados
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}



